{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "UV_CACHE_DIR=\"${CLAUDE_PLUGIN_ROOT}/.uv-cache\" uv run python \"${CLAUDE_PLUGIN_ROOT}/tooling/scripts/quality/validate_after_edit.py\""
          }
        ]
      }
    ]
  }
}
